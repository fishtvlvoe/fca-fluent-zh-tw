#: includes/class-fca-push-profile-widget.php

msgid "FCA Push Notifications requires Fluent Community to be installed and activated."
msgstr "FCA Push Notifications 需要安裝並啟用 Fluent Community。"

msgid "Enable Notifications"
msgstr "啟用通知"

msgid "Get notified about new activity in"
msgstr "接收以下新動態通知"

msgid "Enable"
msgstr "啟用"

msgid "Not now"
msgstr "暫時不要"

msgid "Enabling..."
msgstr "啟用中..."

msgid "Successfully subscribed to push notifications!"
msgstr "已成功訂閱推播通知！"

msgid "Failed to subscribe to push notifications"
msgstr "訂閱推播通知失敗"

msgid "Notification permission denied. Please enable in browser settings."
msgstr "通知權限已被拒絕，請在瀏覽器設定中啟用。"

msgid "Push notifications not supported in this browser."
msgstr "此瀏覽器不支援推播通知。"

msgid "Invalid subscription data"
msgstr "無效的訂閱資料"

msgid "Failed to extract subscription keys"
msgstr "無法擷取訂閱金鑰"

msgid "Failed to save subscription to server"
msgstr "無法將訂閱儲存至伺服器"

msgid "Security check failed"
msgstr "安全性驗證失敗"

msgid "User not logged in"
msgstr "使用者未登入"

msgid "Notification preferences saved successfully"
msgstr "通知偏好設定已儲存"

msgid "Insufficient permissions"
msgstr "權限不足"

msgid "Banner dismissed"
msgstr "橫幅已關閉"

msgid "Stay Connected!"
msgstr "保持連線！"

msgid "Get instant notifications about new messages, posts, and community updates."
msgstr "即時接收新訊息、新文章及社群動態通知。"

msgid "Not Now"
msgstr "暫時不要"

msgid "Notifications enabled successfully!"
msgstr "通知已成功啟用！"

msgid "Notifications are blocked. Please enable them in your browser settings."
msgstr "通知已被封鎖，請在瀏覽器設定中啟用。"

msgid "Notifications require a secure connection (HTTPS)."
msgstr "通知需要安全連線 (HTTPS)。"

msgid "Notifications are not supported in this browser."
